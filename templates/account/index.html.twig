{# Page compte : historique des commandes, accès API et suppression de compte #}
{% extends 'base.html.twig' %}

{% block title %}Mon compte - Green Goodies{% endblock %}

{% block body %}
<section class="account-page">
    <div class="account-container">

        <h1 class="account-title">Mon compte</h1>

        {# Bloc listant les commandes de l'utilisateur connecté #}
        <section class="account-card orders-card">
            <h2 class="account-card-title">Mes commandes</h2>
            <table class="account-orders-table">
                <thead>
                    <tr>
                        <th>N°</th>
                        <th>Date</th>
                        <th>Prix</th>
                    </tr>
                </thead>
                <tbody>
                    {% if orders is empty %}
                    <tr>
                        <td colspan="3">Vous n'avez pas encore de commande.</td>
                    </tr>
                    {% else %}
                        {% for order in orders %}
                            <tr>
                                <td>{{ order.orderNumber }}</td>
                                <td>{{ order.createdAt|date('d/m/Y') }}</td>
                                <td>{{ order.totalPrice|number_format(2, ',', ' ') }}€</td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </section>

        {# Bloc permettant d'activer / désactiver l'accès API #}
        <section class="account-card api-card">
            <h2 class="account-card-title">Mon accès API</h2>
                <form action="{{ path('app_account_api_toggle') }}" method="post">
                    {% if app.user and app.user.apiAccess %}
                        <button type="submit" class="account-button account-button--primary">
                            Désactiver mon accès API
                        </button>
                    {% else %}
                        <button type="submit" class="account-button account-button--primary">
                            Activer mon accès API
                        </button>
                    {% endif %}
                </form>
        </section>

        {# Formulaire de suppression de compte (et des commandes associées) #}
        <section class="account-card delete-card">
            <form action="{{ path('app_account_delete') }}" method="post">
                <button type="submit" class="account-button account-button--danger">
                    Supprimer mon compte
                </button>
            </form>
        </section>

    </div>
</section>
{% endblock %}