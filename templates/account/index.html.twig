                        </tr>
                        <tr>
                            <td>01</td>
                            <td>01/01/2024</td>
                            <td>185,50€</td>
                        </tr>
                    </tbody>
                </table>
            </section>

            <section class="account-card api-card">
                <h2 class="account-card-title">Mon accès API</h2>
                <button class="account-button account-button--primary">
                    Activer mon accès API
                </button>
            </section>

            <section class="account-card delete-card">
                <button class="account-button account-button--danger">
                    Supprimer mon compte
