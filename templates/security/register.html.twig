{% extends 'base.html.twig' %}

{% block title %}Inscription - Green Goodies{% endblock %}

{% block body %}
    <section class="register-page">
        <div class="register-container">
            <div class="register-illustration">
                {# Illustration d'inscription (image à adapter plus tard) #}
                <img src="{{ asset('assets/register.webp') }}" alt="Illustration inscription">
            </div>

            <div class="register-form-wrapper">
                <h1>Inscription</h1>
                <p class="register-info">Tous les champs sont obligatoires.</p>

                <form class="register-form" action="#" method="post">
                    <div class="form-group">
                        <label for="lastname">Nom</label>
                        <input type="text" id="lastname" name="lastname">
                    </div>

                    <div class="form-group">
                        <label for="firstname">Prénom</label>
                        <input type="text" id="firstname" name="firstname">
                    </div>

                    <div class="form-group">
                        <label for="email">Adresse e-mail</label>
                        <input type="email" id="email" name="email">
                    </div>

                    <div class="form-group">
                        <label for="password">Mot de passe</label>
                        <input type="password" id="password" name="password">
                    </div>

                    <div class="form-group">
                        <label for="password_confirm">Confirmer le mot de passe</label>
                        <input type="password" id="password_confirm" name="password_confirm">
                    </div>

                    <div class="form-group register-terms">
                        <label>
                            <input type="checkbox" name="terms">
                            J’accepte les CGU de GreenGoodies
                        </label>
                    </div>

                    <button type="submit" class="register-submit">
                        S'inscrire
                    </button>

                    <p class="register-extra">
                        <a href="{{ path('app_login') }}">
                        Déjà un compte ? Se connecter</a>
                    </p>
                </form>
            </div>
        </div>
    </section>
{% endblock %}