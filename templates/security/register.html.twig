{% extends 'base.html.twig' %}

{% block title %}Inscription - Green Goodies{% endblock %}

{% block body %}
    <section class="register-page">
        <div class="register-container">
            <div class="register-illustration">
                {# Illustration d'inscription (image à adapter plus tard) #}
                <img src="{{ asset('assets/register.webp') }}" alt="">
            </div>

            <div class="register-form-wrapper">
                <h1>Inscription</h1>
                <p class="register-info">Tous les champs sont obligatoires.</p>

                {{ form_start(registrationForm, {'attr': {'class': 'register-form', 'data-turbo': 'false'}}) }}
                    {% set lastNameErrors = form_errors(registrationForm.lastName) %}
                    <div class="form-group">
                        {{ form_label(registrationForm.lastName) }}
                        {{ form_widget(registrationForm.lastName) }}
                        {% if lastNameErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.lastName) }}</div>
                        {% endif %}
                    </div>

                    {% set firstNameErrors = form_errors(registrationForm.firstName) %}
                    <div class="form-group">
                        {{ form_label(registrationForm.firstName) }}
                        {{ form_widget(registrationForm.firstName) }}
                        {% if firstNameErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.firstName) }}</div>
                        {% endif %}
                    </div>

                    {% set emailErrors = form_errors(registrationForm.email) %}
                    <div class="form-group">
                        {{ form_label(registrationForm.email) }}
                        {{ form_widget(registrationForm.email) }}
                        {% if emailErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.email) }}</div>
                        {% endif %}
                    </div>

                    {% set passwordErrors = form_errors(registrationForm.plainPassword.first) %}
                    <div class="form-group">
                        {{ form_label(registrationForm.plainPassword.first) }}
                        {{ form_widget(registrationForm.plainPassword.first) }}
                        {% if passwordErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.plainPassword.first) }}</div>
                        {% endif %}
                    </div>

                    {% set passwordConfirmErrors = form_errors(registrationForm.plainPassword.second) %}
                    <div class="form-group">
                        {{ form_label(registrationForm.plainPassword.second) }}
                        {{ form_widget(registrationForm.plainPassword.second) }}
                        {% if passwordConfirmErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.plainPassword.second) }}</div>
                        {% endif %}
                    </div>

                    {% set termsErrors = form_errors(registrationForm.terms) %}
                    <div class="form-group register-terms">
                        {{ form_widget(registrationForm.terms) }}
                        {{ form_label(registrationForm.terms) }}
                        {% if termsErrors %}
                            <div class="form-error">{{ form_errors(registrationForm.terms) }}</div>
                        {% endif %}
                    </div>

                    <button type="submit" class="register-submit">
                        S'inscrire
                    </button>
                {{ form_end(registrationForm) }}

                <p class="register-extra">
                    <a href="{{ path('app_login') }}">Déjà un compte ? Se connecter</a>
                </p>
            </div>
        </div>
    </section>
{% endblock %}